# Neon Postgres pooled connection
# Usada pela aplicacao em runtime.
# No Neon, copie a connection string com pooling habilitado.
DATABASE_URL="postgresql://USER:PASSWORD@EP-EXEMPLO-pooler.REGIAO.aws.neon.tech/neondb?sslmode=require"

# Neon Postgres direct connection
# Usada pelo Prisma para migrations.
# No Neon, copie a connection string sem pooling.
DIRECT_URL="postgresql://USER:PASSWORD@EP-EXEMPLO.REGIAO.aws.neon.tech/neondb?sslmode=require"

# Senha do painel administrativo
ADMIN_PASSWORD="troque-por-uma-senha-forte"

# URL publica do app
# Local:
# NEXT_PUBLIC_APP_URL="http://localhost:3000"
# Producao:
# NEXT_PUBLIC_APP_URL="https://seu-dominio.vercel.app"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
